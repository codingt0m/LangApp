<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.langapp.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.langapp.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_home_to_quiz"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.example.langapp.ui.QuizFragment"
        android:label="Quiz">
        <argument
            android:name="direction"
            app:argType="string" />
        <argument
            android:name="listId"
            app:argType="string"
            android:defaultValue="all" />
    </fragment>

    <fragment
        android:id="@+id/dictionaryFragment"
        android:name="com.example.langapp.ui.DictionaryFragment"
        android:label="Listes de mots" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.langapp.ui.HistoryFragment"
        android:label="Historique" />

</navigation>